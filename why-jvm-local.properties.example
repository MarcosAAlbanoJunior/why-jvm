# Copie este arquivo para `why-jvm-local.properties` (na raiz do repo) e preencha.
# Esse arquivo COM segredos esta no .gitignore e nao vai pro git.
# Cada chave e lida como system property (-Dchave) ou variavel de ambiente
# equivalente (ex.: LLM_API_KEY, WHYJVM_SMTP_HOST).

# --- IA (Gemini) ---
llm.api-key=sua-chave-do-google-ai-studio
# opcionais (estes sao os defaults):
llm.provider=gemini
llm.model=gemini-2.5-flash

# --- E-mail (SMTP / Gmail) ---
whyjvm.smtp.host=smtp.gmail.com
whyjvm.smtp.port=587
whyjvm.smtp.user=voce@gmail.com
whyjvm.smtp.pass=appPasswordSemEspacos
whyjvm.mail.from=voce@gmail.com
whyjvm.mail.to=voce@gmail.com

# --- Code-aware RCA (Tier 2): mostra o fonte do metodo suspeito no laudo ---
# App-agnostico: o agente in-JVM resolve o fonte (o servico Go nunca o acessa).
# Sem estas chaves, o code-aware degrada honesto para "fonte indisponivel".
#   whyjvm.app.packages: pacotes-raiz da app (lista por virgula), p/ separar o
#                        frame da app do de framework/JDK.
#   whyjvm.source.dirs : diretorios de fonte da app (lista por virgula).
whyjvm.app.packages=com.suaapp
whyjvm.source.dirs=/opt/suaapp/src/main/java
